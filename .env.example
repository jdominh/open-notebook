# Required: encrypt stored API keys (any random string — generate with: openssl rand -hex 32)
OPEN_NOTEBOOK_ENCRYPTION_KEY=change-me-to-a-random-secret-string

# Required: password to access the UI and API
OPEN_NOTEBOOK_PASSWORD=change-me-to-a-strong-password

# Optional: restrict CORS to your domain in production
# CORS_ORIGINS=https://your-domain.com

# SurrealDB (defaults work for local Docker Compose)
SURREAL_USER=root
SURREAL_PASSWORD=root
SURREAL_NAMESPACE=open_notebook
SURREAL_DATABASE=open_notebook
